{
  "name": "mp-mcp",
  "version": "0.0.0",
  "description": "Model Context Protocol server for agents to use UK Parliament data.",
  "keywords": [
    "ai",
    "mcp",
    "model-context-protocol",
    "parliament",
    "uk-parliament",
    "hansard",
    "civic-tech"
  ],
  "author": "James McComish (https://github.com/jamesmccomish)",
  "license": "MIT",
  "homepage": "https://mp-mcp.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamesmccomish/mp-mcp.git",
    "directory": "packages/mp-mcp"
  },
  "bugs": {
    "url": "https://github.com/jamesmccomish/mp-mcp/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "default": "./dist/stdio.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "bin": {
    "mp-mcp": "./dist/stdio.js"
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p evals/tsconfig.json",
    "pretest": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:types": "tsx scripts/gen-types.ts",
    "eval": "tsx evals/runner.ts",
    "bench": "tsx evals/benchmark.ts",
    "start": "node dist/stdio.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "pino": "^9.5.0",
    "undici": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@types/node": "^22.10.1",
    "openapi-typescript": "^7.4.4",
    "swagger2openapi": "^7.0.8",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
