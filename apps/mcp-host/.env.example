PORT=3000

# Langfuse server credentials (optional). When set, each tools/call is timed and a
# server-side span is written to the browser-owned trace, joined by the traceId the
# connector forwards in `authorization_token`. Unset = telemetry off.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com
