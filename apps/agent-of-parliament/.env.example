# MCP host URL the browser points the Anthropic connector at.
NEXT_PUBLIC_MCP_URL=http://localhost:3000/mcp

# Telemetry (optional). When 'true', each turn is POSTed to /api/trace and written
# to Langfuse server-side. The browser holds NO Langfuse credential.
NEXT_PUBLIC_TELEMETRY_ENABLED=false

# Langfuse server credentials — used only by the /api/trace route handler, never
# prefixed NEXT_PUBLIC_, so they stay out of the client bundle.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com
